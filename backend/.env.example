# ──────────────────────────────────────────────
# APP
# ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ──────────────────────────────────────────────
# DATABASE (PostgreSQL + pgvector)
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/living_mind?schema=public"

# ──────────────────────────────────────────────
# REDIS (BullMQ + Cache)
# ──────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ──────────────────────────────────────────────
# CLERK AUTH
# ──────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ──────────────────────────────────────────────
# AI PROVIDERS
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ──────────────────────────────────────────────
# AWS S3
# ──────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_S3_BUCKET=living-mind-uploads
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# ──────────────────────────────────────────────
# STRIPE
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...

# ──────────────────────────────────────────────
# POSTHOG
# ──────────────────────────────────────────────
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://app.posthog.com

# ──────────────────────────────────────────────
# APPLE PUSH NOTIFICATIONS (APNs)
# ──────────────────────────────────────────────
APNS_KEY_ID=...
APNS_TEAM_ID=...
APNS_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APNS_BUNDLE_ID=com.livingmind.app

# ──────────────────────────────────────────────
# ENCRYPTION (AES-256-GCM for PHI fields)
# ──────────────────────────────────────────────
ENCRYPTION_DATA_KEY=<64-char-hex-key — generate: openssl rand -hex 32>

# ──────────────────────────────────────────────
# SAFETY WEBHOOK
# ──────────────────────────────────────────────
SAFETY_WEBHOOK_URL=https://your-safety-webhook.example.com/alert
