generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), pg_trgm, uuid_ossp]
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
}

enum MemoryType {
  FACT
  PREFERENCE
  GOAL
  RELATIONSHIP
  TRIGGER
  EMOTIONAL_EVENT
  LIFE_EVENT
  PATTERN
  INTERVENTION_RESULT
  HABIT_OBSERVATION
}

enum MemorySource {
  EXPLICIT
  INFERRED
  CORROBORATED
  HYPOTHESIZED
}

enum RelationshipType {
  FAMILY
  FRIEND
  PARTNER
  COLLEAGUE
  MENTOR
  THERAPIST
  OTHER
}

enum GoalStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

enum GoalDomain {
  EMOTIONAL
  RELATIONAL
  CAREER
  HEALTH
  PERSONAL
  FINANCIAL
  SPIRITUAL
}

enum HabitFrequency {
  DAILY
  WEEKDAYS
  WEEKENDS
  WEEKLY
  MONTHLY
  CUSTOM
}

enum HabitStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum InsightType {
  PATTERN
  ACHIEVEMENT
  RISK
  GROWTH
  RECOMMENDATION
  MILESTONE
}

enum PatternType {
  EMOTIONAL
  BEHAVIORAL
  RELATIONAL
  COGNITIVE
  SOMATIC
  CYCLICAL
  CONTEXTUAL
}

enum PatternStatus {
  HYPOTHESIZED
  EMERGING
  CONFIRMED
  ARCHIVED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SafetyTier {
  NONE
  DISTRESS
  ELEVATED
  ACUTE
}

enum AIProviderType {
  ANTHROPIC
  OPENAI
  GOOGLE
  LOCAL
}

enum AIModelRole {
  ANALYSIS
  GENERATION
  EMBEDDING
  CLASSIFICATION
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ThreadStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum PredictionType {
  MOOD
  BEHAVIOR
  RISK
  GROWTH
  ENGAGEMENT
}

enum InterventionStrategy {
  WITNESS
  REFLECT
  EXPLORE
  PATTERN
  REFRAME
  EDUCATE
  ACTIVATE
  GROUND
  CHALLENGE
  RESOURCE
  VALIDATE
  CELEBRATE
}

enum AIMode {
  SUPPORT
  COACHING
  REFLECTION
  CRISIS
  EXPLORATION
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  RETRYING
  CANCELLED
}

enum NotificationType {
  CHECK_IN_REMINDER
  INSIGHT_GENERATED
  GOAL_MILESTONE
  PATTERN_DETECTED
  SAFETY_ALERT
  STREAK_ACHIEVED
  WEEKLY_REPORT
  PUSH
  EMAIL
  IN_APP
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
  INCOMPLETE
}

enum SubscriptionTier {
  FREE
  PLUS
  PRO
  TEAM
  ENTERPRISE
}

enum FileType {
  VOICE_NOTE
  IMAGE
  DOCUMENT
  AVATAR
}

enum LifeEventCategory {
  RELATIONSHIP
  CAREER
  HEALTH
  LOSS
  ACHIEVEMENT
  TRANSITION
  TRAUMA
  CELEBRATION
}

// ─── Tenant / Auth ────────────────────────────────────────────────────────────

model Organization {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String  @unique
  name        String
  logoUrl     String?
  website     String?
  description String?
  metadata    Json    @default("{}")
  settings    Json    @default("{}")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  memberships      Membership[]
  livingMindModels LivingMindModel[]
  conversationThreads ConversationThread[]
  insights         Insight[]
  growthReports    GrowthReport[]
  featureFlags     FeatureFlag[]
  apiKeys          APIKey[]
  webhooks         Webhook[]
  auditLogs        AuditLog[]
  stripeCustomers  StripeCustomer[]
  subscriptions    Subscription[]

  @@index([slug])
  @@map("organizations")
}

model User {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerkId        String  @unique
  email          String  @unique
  emailVerified  Boolean @default(false)
  firstName      String?
  lastName       String?
  displayName    String?
  avatarUrl      String?
  phoneNumber    String?
  timezone       String  @default("UTC")
  locale         String  @default("en")
  metadata       Json    @default("{}")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  memberships         Membership[]
  profile             Profile?
  livingMindModel     LivingMindModel?
  emotionalStates     EmotionalState[]
  emotionalEvents     EmotionalEvent[]
  lifeEvents          LifeEvent[]
  relationshipNodes   RelationshipNode[]
  habits              Habit[]
  goals               Goal[]
  triggers            Trigger[]
  copingMechanisms    CopingMechanism[]
  interventions       Intervention[]
  checkIns            CheckIn[]
  journalEntries      JournalEntry[]
  voiceNotes          VoiceNote[]
  conversationThreads ConversationThread[]
  memoryItems         MemoryItem[]
  insights            Insight[]
  predictions         Prediction[]
  notifications       Notification[]
  notificationPreferences NotificationPreference[]
  userSettings        UserSetting[]
  auditLogs           AuditLog[]
  files               File[]
  aiUsageLogs         AIUsageLog[]
  backgroundJobs      BackgroundJob[]
  riskAssessments     RiskAssessment[]
  safetyFlags         SafetyFlag[]
  growthReports       GrowthReport[]
  psychologicalPatterns PsychologicalPattern[]

  @@index([clerkId])
  @@index([email])
  @@map("users")
}

model Membership {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String           @db.Uuid
  organizationId String           @db.Uuid
  role           MembershipRole   @default(MEMBER)
  status         MembershipStatus @default(ACTIVE)
  invitedBy      String?          @db.Uuid
  invitedAt      DateTime?
  joinedAt       DateTime?
  metadata       Json             @default("{}")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@map("memberships")
}

model Profile {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String  @unique @db.Uuid
  organizationId String  @db.Uuid

  dateOfBirth    DateTime?
  gender         String?
  pronouns       String?
  occupation     String?
  location       String?
  bio            String?

  // Onboarding
  onboardingComplete     Boolean @default(false)
  onboardingCompletedAt  DateTime?
  onboardingStep         Int     @default(0)

  // Consent
  consentLmmProfiling    Boolean @default(false)
  consentDataRetention   Boolean @default(false)
  consentResearch        Boolean @default(false)
  consentGivenAt         DateTime?

  // Clinical
  hasTherapist           Boolean @default(false)
  hasMedication          Boolean @default(false)
  hasDiagnosis           Boolean @default(false)
  referralSource         String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@map("profiles")
}

// ─── Living Mind Model ────────────────────────────────────────────────────────

model LivingMindModel {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String @unique @db.Uuid
  organizationId String @db.Uuid

  // Affective Domain
  baselineValence       Float @default(0.0)
  emotionalVolatility   Float @default(0.5)
  emotionalGranularity  Float @default(0.3)
  dominantEmotionProfile Json @default("{}")

  // Personality Signals
  attachmentStyle        String @default("unknown")
  locusOfControl         Float  @default(0.5)
  metacognitiveAwareness Float  @default(0.3)
  openness               Float  @default(0.5)
  conscientiousness      Float  @default(0.5)
  resilience             Float  @default(0.5)
  selfCompassion         Float  @default(0.5)

  // Behavioral Tendencies
  copingStyle     String @default("unknown")
  stressResponse  String @default("unknown")
  conflictStyle   String @default("unknown")

  // Cognitive
  ruminationTendency   Float @default(0.5)
  cognitiveFlexibility Float @default(0.5)

  // Relational
  socialBattery        Float @default(0.5)
  boundaryStrength     Float @default(0.5)

  // Trend Data
  emotionalTrend    Json @default("[]")
  moodCyclePattern  Json @default("{}")

  // Active State
  currentEmotionalState Json @default("{}")
  activeRisks           Json @default("[]")
  activeGoals           Json @default("[]")
  activeTriggers        Json @default("[]")
  activeStressors       Json @default("[]")

  // Growth
  growthAreas                Json @default("[]")
  strengths                  Json @default("[]")
  weaknesses                 Json @default("[]")
  preferredCopingMechanisms  Json @default("[]")
  communicationPreferences   Json @default("{}")

  // Procedural Memory
  interventionEffectiveness Json @default("{}")
  strategyHistory           Json @default("[]")

  // Model Health
  modelVersion      Int     @default(1)
  confidenceScore   Float   @default(0.0)
  totalInteractions Int     @default(0)
  snapshotCount     Int     @default(0)
  lastSnapshotAt    DateTime?
  lastInteractionAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  snapshots    MindSnapshot[]

  @@index([organizationId])
  @@index([userId])
  @@map("living_mind_models")
}

model MindSnapshot {
  id               String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  livingMindModelId String @db.Uuid
  userId           String @db.Uuid
  organizationId   String @db.Uuid

  snapshotVersion  Int
  modelState       Json
  confidenceScore  Float
  triggerReason    String

  createdAt DateTime @default(now())

  livingMindModel LivingMindModel @relation(fields: [livingMindModelId], references: [id])

  @@index([livingMindModelId, createdAt(sort: Desc)])
  @@index([userId])
  @@map("mind_snapshots")
}

// ─── Emotional ────────────────────────────────────────────────────────────────

model EmotionalState {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String @db.Uuid
  organizationId String @db.Uuid

  valence          Float
  arousal          Float
  groundedness     Float
  dominantEmotions String[]
  intensity        Float
  confidence       Float    @default(0.8)

  source       String
  contextId    String?
  contextType  String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([organizationId])
  @@map("emotional_states")
}

model EmotionalEvent {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String @db.Uuid
  organizationId String @db.Uuid

  emotionType  String
  valence      Float
  arousal      Float
  intensity    Float
  trigger      String?
  context      String?
  resolution   String?
  bodyLocation String?

  confidence Float
  source     String

  relatedEntityId   String?
  relatedEntityType String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, emotionType])
  @@index([userId, createdAt(sort: Desc)])
  @@index([organizationId])
  @@map("emotional_events")
}

model LifeEvent {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String            @db.Uuid
  organizationId String            @db.Uuid

  title          String
  description    String?
  category       LifeEventCategory
  impact         Float
  valenceImpact  Float
  occurredAt     DateTime

  isOngoing      Boolean @default(false)
  endsAt         DateTime?

  relatedPersons String[]
  tags           String[]
  metadata       Json    @default("{}")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, occurredAt(sort: Desc)])
  @@index([organizationId])
  @@map("life_events")
}

// ─── Relationship Graph ───────────────────────────────────────────────────────

model RelationshipNode {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String           @db.Uuid
  organizationId String           @db.Uuid

  label          String
  type           RelationshipType
  displayName    String?
  description    String?

  // Metrics
  closeness           Float @default(0.5)
  trust               Float @default(0.5)
  emotionalImpact     Float @default(0.0)
  interactionFreq     Float @default(0.3)
  supportCapacity     Float @default(0.5)
  drainCapacity       Float @default(0.5)
  complexity          Float @default(0.5)

  // Emotional profile
  primaryEmotionWith  String?
  primaryEmotionApart String?
  attachmentPattern   String?

  // History
  mentionFrequency    Json @default("{}")
  conflictHistory     Json @default("[]")
  valenceHistory      Json @default("[]")

  lastMentioned DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user  User               @relation(fields: [userId], references: [id])
  edgesFrom RelationshipEdge[] @relation("EdgeFrom")
  edgesTo   RelationshipEdge[] @relation("EdgeTo")

  @@unique([userId, label])
  @@index([userId, closeness(sort: Desc)])
  @@index([organizationId])
  @@map("relationship_nodes")
}

model RelationshipEdge {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String @db.Uuid

  fromNodeId String @db.Uuid
  toNodeId   String @db.Uuid

  edgeType   String
  weight     Float  @default(0.5)
  metadata   Json   @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fromNode RelationshipNode @relation("EdgeFrom", fields: [fromNodeId], references: [id])
  toNode   RelationshipNode @relation("EdgeTo", fields: [toNodeId], references: [id])

  @@unique([fromNodeId, toNodeId, edgeType])
  @@index([fromNodeId])
  @@index([toNodeId])
  @@map("relationship_edges")
}

// ─── Habits ───────────────────────────────────────────────────────────────────

model HabitCategory {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String @db.Uuid

  name        String
  icon        String?
  color       String?
  description String?
  isSystem    Boolean @default(false)

  createdAt DateTime @default(now())

  habits Habit[]

  @@index([organizationId])
  @@map("habit_categories")
}

model Habit {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String      @db.Uuid
  organizationId String      @db.Uuid
  categoryId     String?     @db.Uuid

  name             String
  description      String?
  targetFrequency  HabitFrequency
  customFrequency  Json?
  status           HabitStatus @default(ACTIVE)

  currentAdherence    Float @default(0.0)
  emotionalCorrelation Json @default("{}")
  stressCorrelation    Float @default(0.0)
  moodImpact           Float @default(0.0)

  streakCurrent Int @default(0)
  streakBest    Int @default(0)
  totalLogs     Int @default(0)

  reminderTime  String?
  reminderDays  String[]
  startDate     DateTime @default(now())
  lastTracked   DateTime?

  metadata Json @default("{}")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user     User           @relation(fields: [userId], references: [id])
  category HabitCategory? @relation(fields: [categoryId], references: [id])
  logs     HabitLog[]
  activities ActivityRecommendation[]

  @@index([userId, status])
  @@index([organizationId])
  @@map("habits")
}

model HabitLog {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  habitId String @db.Uuid
  userId  String @db.Uuid

  completedAt   DateTime
  quality       Float?
  note          String?
  emotionBefore String?
  emotionAfter  String?
  valenceBefore Float?
  valenceAfter  Float?
  duration      Int?

  createdAt DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id])

  @@index([habitId, completedAt(sort: Desc)])
  @@index([userId, completedAt(sort: Desc)])
  @@map("habit_logs")
}

// ─── Goals ────────────────────────────────────────────────────────────────────

model Goal {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String     @db.Uuid
  organizationId String     @db.Uuid

  title          String
  description    String?
  domain         GoalDomain
  status         GoalStatus @default(ACTIVE)

  progress       Float    @default(0.0)
  targetProgress Float    @default(1.0)
  blockers       String[] @default([])
  tags           String[] @default([])

  targetDate  DateTime?
  completedAt DateTime?

  lmmLinked  Boolean @default(true)
  metadata   Json    @default("{}")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user       User              @relation(fields: [userId], references: [id])
  milestones GoalMilestone[]
  progressLogs GoalProgress[]

  @@index([userId, status])
  @@index([organizationId])
  @@map("goals")
}

model GoalMilestone {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  goalId String @db.Uuid
  userId String @db.Uuid

  title       String
  description String?
  completed   Boolean  @default(false)
  completedAt DateTime?
  targetDate  DateTime?
  order       Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id])

  @@index([goalId])
  @@map("goal_milestones")
}

model GoalProgress {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  goalId String @db.Uuid
  userId String @db.Uuid

  progress    Float
  note        String?
  emotionAtLog String?
  valenceAtLog Float?

  loggedAt DateTime @default(now())

  goal Goal @relation(fields: [goalId], references: [id])

  @@index([goalId, loggedAt(sort: Desc)])
  @@map("goal_progress")
}

// ─── Triggers & Coping ───────────────────────────────────────────────────────

model Trigger {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String @db.Uuid
  organizationId String @db.Uuid

  name         String
  description  String?
  category     String
  intensity    Float  @default(0.5)
  frequency    Int    @default(0)
  responseType String?

  firstSeen DateTime  @default(now())
  lastSeen  DateTime?
  contexts  String[]  @default([])

  confidence Float  @default(0.5)
  isActive   Boolean @default(true)
  metadata   Json   @default("{}")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isActive])
  @@index([organizationId])
  @@map("triggers")
}

model CopingMechanism {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String @db.Uuid
  organizationId String @db.Uuid

  name          String
  description   String?
  category      String
  effectiveness Float  @default(0.5)
  usageFrequency Int   @default(0)

  worksFor   String[] @default([])
  contexts   String[] @default([])
  isHealthy  Boolean  @default(true)
  userRated  Boolean  @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([organizationId])
  @@map("coping_mechanisms")
}

// ─── Interventions ────────────────────────────────────────────────────────────

model Intervention {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String               @db.Uuid
  organizationId String               @db.Uuid

  strategy           InterventionStrategy
  mode               AIMode
  sessionId          String?
  threadId           String?           @db.Uuid

  contextEmotionalState Json
  contextSafetyTier     SafetyTier @default(NONE)
  contextTrustLevel     Float      @default(0.5)
  contextTopics         String[]   @default([])

  immediateEngagement Float?
  sessionContinuation Float?
  userFeedback        String?
  overallScore        Float?
  implicitScore       Float?

  scoredAt DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  history  InterventionHistory[]

  @@index([userId, strategy])
  @@index([userId, createdAt(sort: Desc)])
  @@index([organizationId])
  @@map("interventions")
}

model InterventionHistory {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  interventionId String @db.Uuid
  userId         String @db.Uuid

  event     String
  metadata  Json   @default("{}")
  createdAt DateTime @default(now())

  intervention Intervention @relation(fields: [interventionId], references: [id])

  @@index([interventionId])
  @@map("intervention_history")
}

// ─── Activities ───────────────────────────────────────────────────────────────

model Activity {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String @db.Uuid

  name         String
  description  String?
  category     String
  tags         String[] @default([])
  isSystem     Boolean  @default(false)
  moodImpact   Float    @default(0.0)
  energyImpact Float    @default(0.0)
  duration     Int?

  createdAt DateTime @default(now())

  recommendations ActivityRecommendation[]

  @@index([organizationId])
  @@map("activities")
}

model ActivityRecommendation {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String @db.Uuid
  organizationId String @db.Uuid
  activityId     String @db.Uuid
  habitId        String? @db.Uuid

  reason      String?
  score       Float   @default(0.5)
  completed   Boolean @default(false)
  completedAt DateTime?
  feedback    String?

  expiresAt DateTime?
  createdAt DateTime  @default(now())

  activity Activity @relation(fields: [activityId], references: [id])
  habit    Habit?   @relation(fields: [habitId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@map("activity_recommendations")
}

model Hobby {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String @db.Uuid
  organizationId String @db.Uuid

  name          String
  category      String
  enjoymentLevel Float @default(0.7)
  frequency      Float @default(0.3)
  lastEngaged    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("hobbies")
}

// ─── Routines ─────────────────────────────────────────────────────────────────

model RoutineProfile {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String @unique @db.Uuid
  organizationId String @db.Uuid

  wakeTime     String?
  sleepTime    String?
  workStart    String?
  workEnd      String?
  exerciseTime String?
  mealTimes    Json    @default("[]")
  freeTimeSlots Json   @default("[]")

  sleepQuality    Float @default(0.5)
  routineAdherence Float @default(0.5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events RoutineEvent[]

  @@index([organizationId])
  @@map("routine_profiles")
}

model RoutineEvent {
  id               String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  routineProfileId String @db.Uuid
  userId           String @db.Uuid

  name      String
  category  String
  startTime String
  endTime   String?
  days      String[]
  isFixed   Boolean @default(false)
  metadata  Json    @default("{}")

  createdAt DateTime @default(now())

